# Server Configuration
PORT=3001
NODE_ENV=production

# JWT Authentication
JWT_SECRET=your-very-long-random-secret-here-change-this-in-production-with-32-chars-minimum
JWT_EXPIRES_IN=7d

# MySQL Database (Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afrivogue_db
DB_USER=afrivogue_user
DB_PASSWORD=your-secure-db-password-here

# Email - Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@afrivogue.com
SMTP_PASS=your-email-password-here
EMAIL_FROM_NAME=AfriVogue
EMAIL_FROM_ADDRESS=hello@afrivogue.com
CONTACT_EMAIL=contact@afrivogue.com

# Site Configuration
SITE_URL=https://afrivogue.com
SITE_NAME=AfriVogue

# Stripe (optional - for shop checkout)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
