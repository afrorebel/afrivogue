# AfriVogue Frontend Environment Variables
# Rename this file to .env before building or running the dev server

# URL of your Node.js backend API (on Hostinger, this is your domain)
# Development: http://localhost:3001/api
# Production:  https://afrivogue.com/api  (if Node.js runs on same domain)
#           OR https://api.afrivogue.com/api (if using a separate subdomain)
VITE_API_URL=http://localhost:3001/api

# Remove these — no longer needed (Supabase has been replaced):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
